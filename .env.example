# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=replace-with-secret-manager-value
LINE_CHANNEL_SECRET=replace-with-secret-manager-value

# LINE Login (the Login channel must be under the same Provider as Messaging API)
LINE_LOGIN_CHANNEL_ID=replace-with-channel-id
LINE_LOGIN_CHANNEL_SECRET=replace-with-secret-manager-value
LINE_LOGIN_REDIRECT_URI=http://localhost:5000/auth/line/callback
SESSION_SECRET=replace-with-at-least-32-random-bytes
AUTH_COOKIE_SECURE=false

# Firestore and private artifacts
GCP_PROJECT_ID=replace-with-project-id
QUANT_SNAPSHOT_BUCKET=replace-with-private-bucket-name
